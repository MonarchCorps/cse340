<%- include('./partials/header', { title }) %>

	<section class="page-hero">
		<div class="container">
			<h1>
				<%= title %>
			</h1>
			<p>Find meaningful service projects and start making a difference today.</p>
		</div>
	</section>

	<section class="projects-section">
		<div class="container">
			<div class="project-list">

				<% if (projects && projects.length) { %>
					<% projects.forEach(function(project) { %>
					<article class="project-card">
						<div class="project-meta">
							<span class="project-category"><%= project.categories || 'Uncategorized' %></span>
							<span class="project-org"><%= project.organization_name %></span>
						</div>
						<h2><%= project.title %></h2>
						<p><%= project.description %></p>
						<ul class="project-details">
							<li><strong>Location:</strong> <%= project.location %></li>
							<li><strong>Time Commitment:</strong> <%= project.time_commitment %></li>
							<li><strong>Volunteers Needed:</strong> <%= project.volunteers_needed %></li>
						</ul>
					</article>
					<% }) %>
				<% } else { %>
					<p>No projects available.</p>
				<% } %>

			</div>
		</div>
	</section>

	<%- include('./partials/footer') %>