<%- include('./partials/header', { title }) %>

	<section class="page-hero">
		<div class="container">
			<h1>
				<%= title %>
			</h1>
			<p>Find meaningful service projects and start making a difference today.</p>
		</div>
	</section>

	<section class="projects-section">
		<div class="container">
			<div class="project-list">

				<article class="project-card">
					<div class="project-meta">
						<span class="project-category">Environmental</span>
						<span class="project-org">Green Earth Foundation</span>
					</div>
					<h2>City Park Cleanup</h2>
					<p>Join us every Saturday morning to clean up litter, restore trails, and plant native species in
						our local parks.</p>
					<ul class="project-details">
						<li><strong>Location:</strong> Central Park</li>
						<li><strong>Time Commitment:</strong> 3 hours / week</li>
						<li><strong>Volunteers Needed:</strong> 20</li>
					</ul>
				</article>

				<article class="project-card">
					<div class="project-meta">
						<span class="project-category">Educational</span>
						<span class="project-org">Bright Minds Academy</span>
					</div>
					<h2>After-School Tutoring Program</h2>
					<p>Provide one-on-one tutoring in math, science, and reading to students in grades 3–8 after school
						hours.</p>
					<ul class="project-details">
						<li><strong>Location:</strong> Eastside Community Center</li>
						<li><strong>Time Commitment:</strong> 2 hours / week</li>
						<li><strong>Volunteers Needed:</strong> 15</li>
					</ul>
				</article>

				<article class="project-card">
					<div class="project-meta">
						<span class="project-category">Community Service</span>
						<span class="project-org">Community Care Network</span>
					</div>
					<h2>Monthly Food Drive</h2>
					<p>Help collect, sort, and distribute food donations to families in need throughout the city.</p>
					<ul class="project-details">
						<li><strong>Location:</strong> Downtown Food Bank</li>
						<li><strong>Time Commitment:</strong> 4 hours / month</li>
						<li><strong>Volunteers Needed:</strong> 30</li>
					</ul>
				</article>

				<article class="project-card">
					<div class="project-meta">
						<span class="project-category">Health and Wellness</span>
						<span class="project-org">Community Care Network</span>
					</div>
					<h2>Community Health Fair</h2>
					<p>Assist with organizing and running free health screenings, fitness workshops, and wellness
						consultations.</p>
					<ul class="project-details">
						<li><strong>Location:</strong> Riverside Convention Center</li>
						<li><strong>Time Commitment:</strong> 6 hours (one-time event)</li>
						<li><strong>Volunteers Needed:</strong> 50</li>
					</ul>
				</article>

			</div>
		</div>
	</section>

	<%- include('./partials/footer') %>