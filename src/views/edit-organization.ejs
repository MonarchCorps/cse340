<%- include('./partials/header', { title }) %>

    <section class="page-hero">
        <div class="container">
            <h1><%= title %></h1>
            <p>Update the organization details below.</p>
        </div>
    </section>

    <section class="form-page">
        <div class="container">
            <% if (organizationDetails) { %>
                <div class="form-card">
                    <form action="/edit-organization/<%= organizationDetails.organization_id %>" method="POST">
                        <div class="form-group">
                            <label for="name">Organization Name</label>
                            <input
                                type="text"
                                id="name"
                                name="name"
                                value="<%= organizationDetails.name %>"
                                maxlength="150"
                                required
                            />
                        </div>

                        <div class="form-group">
                            <label for="description">Description</label>
                            <textarea
                                id="description"
                                name="description"
                                maxlength="500"
                                required
                            ><%= organizationDetails.description %></textarea>
                        </div>

                        <div class="form-group">
                            <label for="contactEmail">Contact Email</label>
                            <input
                                type="email"
                                id="contactEmail"
                                name="contactEmail"
                                value="<%= organizationDetails.contact_email %>"
                                required
                            />
                        </div>

                        <div class="form-actions">
                            <button type="submit" class="btn btn-primary">Save Changes</button>
                            <a href="/organization/<%= organizationDetails.organization_id %>" class="btn btn-outline">Cancel</a>
                        </div>
                    </form>
                </div>
            <% } else { %>
                <p>Organization not found. <a href="/organizations">Back to organizations</a>.</p>
            <% } %>
        </div>
    </section>

<%- include('./partials/footer') %>
