<%- include('./partials/header', { title }) %>

    <section class="page-hero">
        <div class="container">
            <h1><%= title %></h1>
            <p>Service projects in this category.</p>
            <% if (category && isAdmin) { %>
                <a href="/edit-category/<%= category.category_id %>" class="btn btn-primary" style="margin-top: 1rem; display: inline-block;">Edit Category</a>
            <% } %>
        </div>
    </section>

    <section class="projects-section">
        <div class="container">
            <% if (category) { %>
                <% if (projects && projects.length) { %>
                    <div class="project-list">
                        <% projects.forEach(function(project) { %>
                        <article class="project-card">
                            <h2><a href="/project/<%= project.project_id %>"><%= project.title %></a></h2>
                            <p><%= project.description %></p>
                            <ul class="project-details">
                                <li><strong>Location:</strong> <%= project.location %></li>
                                <li><strong>Date:</strong> <%= new Date(project.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></li>
                            </ul>
                        </article>
                        <% }) %>
                    </div>
                <% } else { %>
                    <p>No service projects found for this category.</p>
                <% } %>
            <% } else { %>
                <p>Category not found.</p>
            <% } %>
        </div>
    </section>

<%- include('./partials/footer') %>
