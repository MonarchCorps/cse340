<%- include('partials/header') %>

<section class="page-hero">
    <div class="container">
        <h1>My Dashboard</h1>
        <p>Welcome back, <%= name %>!</p>
    </div>
</section>

<div class="dashboard-section">
    <div class="container">

        <div class="user-card">
            <div class="user-avatar"><%= name.charAt(0).toUpperCase() %></div>
            <div class="user-info">
                <h2><%= name %></h2>
                <p><%= email %></p>
                <span class="user-badge">Member</span>
            </div>
        </div>

        <div class="dashboard-grid">
            <div class="dashboard-card">
                <h3>Browse Organizations</h3>
                <p>Explore nonprofits and groups looking for volunteers in your area.</p>
                <a href="/organizations" class="btn btn-outline">View Organizations</a>
            </div>
            <div class="dashboard-card">
                <h3>Find Projects</h3>
                <p>Discover service projects across multiple categories that need your help.</p>
                <a href="/projects" class="btn btn-outline">Browse Projects</a>
            </div>
            <div class="dashboard-card">
                <h3>Explore Categories</h3>
                <p>Browse volunteer opportunities by category to find what matters most to you.</p>
                <a href="/categories" class="btn btn-outline">View Categories</a>
            </div>
        </div>

    </div>
</div>

<%- include('partials/footer') %>
